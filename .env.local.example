# Supabase — copie este arquivo para .env.local e preencha com suas credenciais
# Crie um projeto em https://supabase.com e obtenha as chaves em Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Apenas para scripts server-side — NUNCA expor no cliente
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
